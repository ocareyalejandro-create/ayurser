# Ayurser — Postgres persistence (optional, wired but dormant).
#
# Without this, the app runs fine and the check-in works — it simply does not
# remember. Add it to a local `.env.local` (gitignored) to activate persistence,
# then run migrations/0001_check_ins.sql against your database.
#
# This is a SECRET, server-only connection string (Neon / Vercel Postgres).
# It is NOT a public browser key — it must never be prefixed NEXT_PUBLIC_ and
# never reaches the client. All DB access happens server-side in
# app/api/check-in/route.ts.
#
# The app reads DATABASE_URL first, then falls back to POSTGRES_URL (Vercel's
# Neon integration may inject either name). Setting one is enough.

DATABASE_URL=postgres://user:password@host/dbname?sslmode=require
# POSTGRES_URL=   # alternative name auto-provisioned by the Vercel Neon integration
