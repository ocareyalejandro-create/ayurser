# Ayurser — Supabase (optional, wired but dormant).
#
# Without these, the app runs fine and the check-in works — it simply does not
# remember. Add them to a local `.env.local` (gitignored) to activate persistence,
# then run supabase/migrations/0001_check_ins.sql against your project.
#
# Both are PUBLIC (browser-safe) values — never put service-role keys here.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
